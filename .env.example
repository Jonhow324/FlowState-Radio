# ============================================
# Claudio - AI Music Radio DJ Environment Config
# ============================================

# AI Brain (OpenCode CLI) — Phase 2
ANTHROPIC_API_KEY=sk-ant-xxx
AI_MODEL=claude-sonnet-4-6

# TTS (Minimax) — Phase 3
MINIMAX_API_KEY=xxx
MINIMAX_GROUP_ID=xxx
MINIMAX_VOICE_ID_ZH=default
MINIMAX_VOICE_ID_EN=default

# Weather (OpenWeather) — Phase 2
OPENWEATHER_API_KEY=xxx
